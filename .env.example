# === FiinQuantX ===
FIINQUANT_USERNAME=your_username@email.com
FIINQUANT_PASSWORD=your_password

# === PostgreSQL (local Docker) ===
DATABASE_URL=postgresql+asyncpg://fbot:fbot_password@localhost:5432/fbot
DATABASE_URL_SYNC=postgresql://fbot:fbot_password@localhost:5432/fbot

# --- Hoặc dùng Supabase ---
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require
# DATABASE_URL_SYNC=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require

# Redis: không cần, bỏ qua hoàn toàn

# === Resend Email ===
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=alerts@yourdomain.com
RESEND_TO=recipient@email.com

# === App Config ===
APP_ENV=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Ho_Chi_Minh

# === Alert Thresholds (optional overrides) ===
THRESHOLD_NORMAL=2.0
THRESHOLD_MAGIC=1.5
THRESHOLD_CONFIRM_15M=1.3
BREAKOUT_VOL_MULT=3.0
BREAKOUT_PRICE_PCT=0.03
ALERT_DAYS_BEFORE_CYCLE=10
